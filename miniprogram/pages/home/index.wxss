.page-shell { min-height: 100vh; }
.hero { padding: 36rpx 32rpx 40rpx; background: linear-gradient(145deg, #e7fff4 0%, #f7fffb 62%, #fff 100%); border-bottom: 1rpx solid #d9f2e8; }
.brand-row { display: flex; align-items: center; gap: 18rpx; margin-bottom: 42rpx; }
.brand-mark { width: 68rpx; height: 68rpx; border-radius: 20rpx; display: flex; align-items: center; justify-content: center; background: #064e3b; color: white; font-size: 34rpx; font-weight: 800; box-shadow: 0 10rpx 24rpx rgba(6,78,59,.16); }
.brand-copy { display: flex; flex-direction: column; flex: 1; }
.brand-copy text:first-child { font-size: 31rpx; font-weight: 800; }
.brand-copy text:last-child { font-size: 22rpx; color: #67847b; margin-top: 2rpx; }
.copy-button::after, .date-chip::after, .view-tab::after, .week-card button::after { border: 0; }
.eyebrow { display: block; color: #047857; font-size: 23rpx; font-weight: 700; letter-spacing: 2rpx; margin-bottom: 16rpx; }
.live-dot { display: inline-block; width: 12rpx; height: 12rpx; border-radius: 50%; background: #10b981; box-shadow: 0 0 0 8rpx rgba(16,185,129,.1); }
.hero-title { display: block; font-size: 54rpx; line-height: 1.2; font-weight: 900; letter-spacing: -2rpx; max-width: 650rpx; }
.hero-desc { display: block; color: #53736a; font-size: 27rpx; line-height: 1.8; margin-top: 22rpx; }
.date-panel { padding: 24rpx 28rpx 8rpx; background: #fff; }
.date-picker { height: 92rpx; border-radius: 22rpx; background: #effaf6; border: 1rpx solid #d7eee6; display: flex; align-items: center; padding: 0 26rpx; gap: 18rpx; }
.date-picker .strong { flex: 1; font-size: 32rpx; }
.date-picker text { color: #668078; font-size: 24rpx; }
.date-chips { white-space: nowrap; margin-top: 16rpx; }
.date-chips-inner, .view-tabs-inner { display: inline-flex; gap: 14rpx; padding-bottom: 12rpx; }
.date-chip { margin: 0; padding: 0 25rpx; height: 60rpx; line-height: 60rpx; border-radius: 30rpx; border: 0; color: #5d766e; background: #f3f7f5; font-size: 24rpx; }
.date-chip.is-active { background: #064e3b; color: #fff; }
.view-tabs { white-space: nowrap; background: #fff; border-bottom: 1rpx solid #e4eee9; position: sticky; top: 0; z-index: 8; }
.view-tabs-inner { padding: 14rpx 28rpx 16rpx; }
.view-tab { margin: 0; padding: 0 24rpx; height: 64rpx; line-height: 64rpx; border: 0; border-radius: 18rpx; color: #667d76; background: #fff; font-size: 24rpx; }
.view-tab.is-active { color: #047857; background: #eaf8f2; font-weight: 700; }
.content { padding: 28rpx; }
.card { background: #fff; border: 1rpx solid #e1eee9; border-radius: 28rpx; box-shadow: 0 12rpx 36rpx rgba(30,82,66,.06); }
.lead-card { padding: 38rpx 34rpx; background: linear-gradient(135deg, #064e3b, #08795c); color: #fff; }
.kicker { display: block; color: #0a8f6a; font-size: 22rpx; font-weight: 800; letter-spacing: 1rpx; }
.lead-card .kicker { color: #a7f3d0; }
.lead-title { display: block; font-size: 43rpx; font-weight: 900; line-height: 1.35; margin: 18rpx 0; }
.lead-summary { display: block; color: rgba(255,255,255,.82); line-height: 1.75; }
.copy-button { margin: 28rpx 0 0; width: 240rpx; height: 68rpx; line-height: 68rpx; padding: 0; border-radius: 34rpx; background: rgba(255,255,255,.14); border: 1rpx solid rgba(255,255,255,.28); color: #fff; font-size: 24rpx; }
.stats-card { display: flex; flex-wrap: wrap; margin-top: 22rpx; padding: 20rpx 10rpx; }
.stats-card view { width: 25%; min-width: 150rpx; flex: 1; padding: 18rpx 8rpx; text-align: center; box-sizing: border-box; }
.stats-card .strong, .stats-card text { display: block; }
.stats-card .strong { font-size: 36rpx; color: #075c46; }
.stats-card text { margin-top: 6rpx; color: #71877f; font-size: 21rpx; }
.section-head { padding: 42rpx 8rpx 20rpx; }
.section-head .strong { display: block; margin-top: 10rpx; font-size: 36rpx; line-height: 1.35; }
.insight { padding: 30rpx; display: flex; gap: 24rpx; margin-bottom: 20rpx; }
.insight-index { color: #78bca6; font-weight: 800; font-size: 25rpx; padding-top: 4rpx; }
.insight-body { flex: 1; }
.insight-body .strong, .insight-body text, .insight-body .small { display: block; }
.tag { display: inline-block !important; width: fit-content; padding: 6rpx 14rpx; border-radius: 10rpx; color: #08795c; background: #eaf8f2; font-size: 21rpx; font-weight: 700; }
.insight-body .strong { font-size: 31rpx; line-height: 1.5; margin: 16rpx 0 10rpx; }
.insight-body text { color: #587069; line-height: 1.7; }
.insight-body .small { color: #93a59f; margin-top: 14rpx; font-size: 21rpx; }
.action-card { display: flex; align-items: flex-start; gap: 22rpx; padding: 30rpx; margin-bottom: 18rpx; }
.action-card.is-done { opacity: .56; }
.action-card view { flex: 1; }
.action-card .strong, .action-card text { display: block; }
.action-card .strong { font-size: 31rpx; margin: 8rpx 0 12rpx; }
.action-card text { color: #60766f; line-height: 1.65; }
.action-number { color: #0a8f6a !important; font-size: 21rpx; font-weight: 800; }
.tip { padding: 26rpx; border-radius: 20rpx; background: #eef8f4; color: #587069; line-height: 1.65; font-size: 24rpx; }
.weekly-summary { padding: 32rpx; }
.weekly-summary .strong, .weekly-summary text { display: block; }
.weekly-summary .strong { font-size: 32rpx; line-height: 1.5; }
.weekly-summary text { margin-top: 16rpx; color: #637970; line-height: 1.7; }
.week-card { padding: 28rpx; margin-top: 18rpx; }
.week-card text, .week-card .strong { display: block; }
.week-card text { color: #779087; font-size: 23rpx; }
.week-card .strong { font-size: 29rpx; line-height: 1.5; margin: 10rpx 0; }
.week-card button { margin: 12rpx 0 0; padding: 0; width: 150rpx; height: 58rpx; line-height: 58rpx; border-radius: 29rpx; border: 0; background: #eaf8f2; color: #08795c; font-size: 23rpx; }
.resource-card { padding: 30rpx; margin-bottom: 18rpx; }
.resource-card .strong, .resource-card > text:last-child { display: block; }
.resource-card .strong { font-size: 31rpx; margin: 16rpx 0 10rpx; }
.resource-card > text:last-child { color: #5e756d; line-height: 1.7; }
.content-links { display: flex; flex-wrap: wrap; gap: 12rpx; margin-top: 18rpx; }
.content-links button { margin: 0; padding: 0 20rpx; min-height: 58rpx; line-height: 58rpx; border: 1rpx solid #bfe8da; border-radius: 29rpx; background: #eefaf5; color: #08795c; font-size: 22rpx; }
.content-links button::after { border: 0; }
.timeline { padding: 10rpx 30rpx; }
.timeline-item { display: flex; gap: 24rpx; padding: 30rpx 0; border-bottom: 1rpx solid #e4eee9; }
.timeline-item:last-child { border-bottom: 0; }
.timeline-time { color: #0a8f6a; font-weight: 800; font-size: 23rpx; padding-top: 3rpx; }
.timeline-item view { flex: 1; }
.timeline-item .strong, .timeline-item view text { display: block; }
.timeline-item .strong { font-size: 29rpx; margin-bottom: 10rpx; }
.timeline-item view text { color: #61776f; line-height: 1.7; }
.timeline + .tip { margin-top: 20rpx; }
